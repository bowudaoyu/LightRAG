    {
      "id": "DYN_NMC_20260405_015",
      "category": "content",
      "title": "策展人手记：为什么叫'后母戊鼎'而不是'司母戊鼎'？",
      "description": "国博青铜器研究室李主任撰文详解这个持续了半个多世纪的命名之争。1959年郭沫若定名'司母戊鼎'，2011年国博正式更名为'后母戊鼎'。'后'指的是'伟大的母亲'，而非'之后'的意思——这一字之差的背后，是对殷商王室祭祀文化更深入的理解。",
      "priority": 2,
      "status": "active",
      "valid_from": "2026-04-03T09:00:00+08:00",
      "valid_to": "2026-12-31T23:59:59+08:00",
      "zone_ids": ["CN_NMC_ZONE_B1_NORTH"],
      "artifact_ids": ["ART_NMC_001"],
      "exhibition_ids": ["EXH_NMC_001"],
      "theme_ids": ["THEME_NMC_001"],
      "tags": ["后母戊鼎", "命名争议", "冷知识", "策展人解读", "青铜器"],
      "target_audience": ["culture_enthusiast", "student"],
      "payload": {
        "content_type": "curator_insight",
